 abstract = {Abstract This article dwells on the nature of {\textquotedblleft}inverted bonds{\textquotedblright}, which refer to the \ensuremath{\sigma} interaction between two sp hybrids by their smaller lobes, and their presence in [1.1.1]propellane. Firstly, we study H3C\ensuremath{-}C models of C\ensuremath{-}C bonds with frozen H-C-C angles reproducing the constraints of various degrees of {\textquotedblleft}inversion{\textquotedblright}. Secondly, the molecular orbital (MO) properties of [1.1.1]propellane and [1.1.1]bicyclopentane are analyzed with the help of orbital forces as a criterion of bonding/antibonding character and as a basis to evaluate bond energies. Triplet and cationic states of [1.1.1]propellane species are also considered to confirm the bonding/antibonding character of MOs in the parent molecule. These approaches show an essentially non-bonding character of the \ensuremath{\sigma} central C\ensuremath{-}C interaction in propellane. Within the MO theory, this bonding is thus only due to \ensuremath{\pi}-type MOs (also called {\textquotedblleft}banana{\textquotedblright} MOs or {\textquotedblleft}bridge{\textquotedblright} MOs) and its total energy is evaluated to approximately 50 kcal mol\ensuremath{-}1. In bicyclopentane, despite a strong \ensuremath{\sigma}-type repulsion, a weak bonding (15{\textendash}20 kcal mol\ensuremath{-}1) exists between both central C\ensuremath{-}C bonds, also due to \ensuremath{\pi}-type interactions, though no bond is present in the Lewis structure. Overall, the so-called {\textquotedblleft}inverted{\textquotedblright} bond, as resulting from a \ensuremath{\sigma} overlap of the two sp hybrids by their smaller lobes, appears highly questionable.},
 year = {2020},
 source = {Crossref},
 publisher = {Wiley},
 issn = {0947-6539, 1521-3765},
 month = feb,
 url = {https://doi.org/10.1002/chem.201904910},
}

